{
  "name": "@cameronbrady/math-components",
  "version": "0.5.0",
  "description": "Accessible, interactive math components — a coordinate-plane transformations Grapher plus framework-agnostic geometry, grading, and progress logic.",
  "license": "MIT",
  "private": false,
  "author": "Cameron Brady",
  "homepage": "https://resources.cameronbrady.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameronbrady1527/portfolio-v2.git",
    "directory": "packages/math-components"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "math",
    "education",
    "interactive",
    "geometry",
    "transformations",
    "mafs",
    "react",
    "accessible"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./logic": {
      "import": {
        "types": "./dist/logic/index.d.ts",
        "default": "./dist/logic/index.js"
      },
      "require": {
        "types": "./dist/logic/index.d.cts",
        "default": "./dist/logic/index.cjs"
      }
    },
    "./dsl": {
      "import": {
        "types": "./dist/GrapherTypes.d.ts",
        "default": "./dist/GrapherTypes.js"
      },
      "require": {
        "types": "./dist/GrapherTypes.d.cts",
        "default": "./dist/GrapherTypes.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0 || true",
    "test": "tsup && vitest run"
  },
  "dependencies": {
    "katex": "^0.16.47",
    "lucide-react": "^0.546.0",
    "mafs": "^0.21.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
